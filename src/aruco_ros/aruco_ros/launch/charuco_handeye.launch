<launch>
    <!-- 参数配置 (默认值) -->
    <arg name="dictionary_name" default="DICT_4X4_50" doc="ArUco字典名称" />
    <arg name="squares_x"       default="11"     doc="棋盘格横向方块数" />
    <arg name="squares_y"       default="8"     doc="棋盘格纵向方块数" />
    <arg name="square_length"   default="0.011" doc="黑色方块边长 (米)" />
    <arg name="marker_length"   default="0.015" doc="内部ArUco码边长 (米)" />
    
    <arg name="camera_frame"    default="camera_color_optical_frame" doc="相机光心坐标系" />
    <arg name="board_frame"     default="charuco_board_frame" doc="发布的标定板坐标系名称" />

    <!-- 启动 ChArUco 检测节点 -->
    <node pkg="aruco_ros" type="charuco_detector.py" name="charuco_detector" output="screen">
        <param name="dictionary_name" value="$(arg dictionary_name)" />
        <param name="squares_x"       value="$(arg squares_x)" />
        <param name="squares_y"       value="$(arg squares_y)" />
        <param name="square_length"   value="$(arg square_length)" />
        <param name="marker_length"   value="$(arg marker_length)" />
        <param name="camera_frame"    value="$(arg camera_frame)" />
        <param name="board_frame"     value="$(arg board_frame)" />
    </node>
</launch>
