<launch>
    <!-- 1. 启动 ChArUco 检测节点 -->
    <include file="$(find aruco_ros)/launch/charuco_handeye.launch">
        <arg name="camera_frame" value="camera_color_optical_frame" />
        <arg name="board_frame" value="charuco_board_frame" />
    </include>

    <!-- 2. 封装 Kinova m1n6s200 + ChArUco 的手眼标定配置 -->
    <include file="$(find easy_handeye)/launch/calibrate.launch">
        <!-- 标定类型：眼在手上 -->
        <arg name="eye_on_hand" value="true" />
        
        <!-- 机械臂坐标系 -->
        <arg name="robot_base_frame" value="m1n6s200_link_base" />
        <arg name="robot_effector_frame" value="m1n6s200_end_effector" />
        
        <!-- 追踪坐标系 (ChArUco) -->
        <!-- 注意：必须使用 Optical Frame 以保证方向正确 -->
        <arg name="tracking_base_frame" value="camera_color_optical_frame" />
        <arg name="tracking_marker_frame" value="charuco_board_frame" />
        
        <!-- 移动模式：允许手动拖动机械臂 (更安全) -->
        <arg name="freehand_robot_movement" value="true" />
    </include>
</launch>
