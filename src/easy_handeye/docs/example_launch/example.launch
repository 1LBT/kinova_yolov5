<launch>
    <arg name="namespace_prefix" value="m1n6s200_handeyecalibration"/>
 
    <arg name="marker_size" doc="Size of the ArUco marker used, in meters" default="0.1"/>
    <arg name="marker_id" doc="The ID of the ArUco marker used" default="582"/>
 
 
    <!-- start the Realsense405
    <include file="$(find realsense2_camera)/camera_ws/src/realsense-ros/realsense2_camera/launch/rs_camera.launch" >
        <arg name="publish_tf" value="false" />
    </include>
     -->
     <!-- 3. ArUco 跟踪 -->
    <node name="aruco_tracker" pkg="aruco_ros" type="single" output="screen">
        <remap from="/camera_info" to="/camera/color/camera_info"/>
        <remap from="/image"       to="/camera/color/image_raw"/>
        <param name="image_is_rectified" value="true"/>
        <param name="marker_size"  value="$(arg marker_size)"/>
        <param name="marker_id"    value="$(arg marker_id)"/>
        <!-- eye-in-hand：相机装在末端，这里填末端帧 -->
        <param name="reference_frame" value="m1n6s200_end_effector"/>
        <param name="camera_frame"    value="camera_color_frame"/>
        <param name="marker_frame"    value="aruco_marker_frame"/>
    </node>

    <!-- 4. easy-handeye 标定 -->
    <include file="$(find easy_handeye)/launch/calibrate.launch">
        <arg name="namespace_prefix" value="$(arg namespace_prefix)"/>
        <arg name="eye_on_hand"      value="true"/>          <!-- 眼在手上 -->
        <arg name="tracking_base_frame"  value="camera_color_frame"/>
        <arg name="tracking_marker_frame" value="aruco_marker_frame"/>
        <!-- Kinova 基座和末端帧名 -->
        <arg name="robot_base_frame"     value="m1n6s200_link_base"/>
        <arg name="robot_effector_frame" value="m1n6s200_end_effector"/>
        <!-- 用 MoveIt 规划采样轨迹 -->
        <arg name="freehand_robot_movement" value="false"/>
        <arg name="robot_velocity_scaling"  value="0.3"/>
        <arg name="robot_acceleration_scaling" value="0.2"/>
    </include>
</launch>